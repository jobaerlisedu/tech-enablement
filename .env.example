# =============================================================
# Tech Enablement — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# =============================================================

# --- Django Core ---
# Generate a strong secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-strong-random-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (e.g. your-app.onrender.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Firebase Configuration ---
# Path to local service account JSON file (for local development)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# For production: paste the raw JSON content of firebase-credentials.json here
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Firebase project settings (find in Firebase Console > Project Settings)
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# --- Optional Production Overrides ---
# Override CSRF trusted origins (comma-separated full origins with scheme)
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Set to False if your host/proxy handles SSL termination (e.g. Render, Heroku)
# SECURE_SSL_REDIRECT=True

# HSTS duration in seconds (default: 31536000 = 1 year)
# SECURE_HSTS_SECONDS=31536000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
